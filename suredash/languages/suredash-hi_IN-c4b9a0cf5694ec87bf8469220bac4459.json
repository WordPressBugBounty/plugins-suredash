{"translation-revision-date":"2024-12-18T19:51:59+00:00","generator":"WP-CLI\/2.10.0","source":"assets\/js\/unminified\/login.js","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","lang":"en","plural-forms":"nplurals=2; plural=(n != 1);"},"Please check your email for the password reset link.":["\u0915\u0943\u092a\u092f\u093e \u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u0930\u0940\u0938\u0947\u091f \u0932\u093f\u0902\u0915 \u0915\u0947 \u0932\u093f\u090f \u0905\u092a\u0928\u0947 \u0908\u092e\u0947\u0932 \u0915\u0940 \u091c\u093e\u0902\u091a \u0915\u0930\u0947\u0902\u0964"],"Passwords do not match.":["\u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u092e\u0947\u0932 \u0928\u0939\u0940\u0902 \u0916\u093e\u0924\u0947\u0964"],"Sending\u2026":["\u092d\u0947\u091c\u0928\u093e\u2026"],"This field cannot be blank.":["\u092f\u0939 \u092b\u093c\u0940\u0932\u094d\u0921 \u0916\u093e\u0932\u0940 \u0928\u0939\u0940\u0902 \u0939\u094b \u0938\u0915\u0924\u0940\u0964"],"Error:":["\u0924\u094d\u0930\u0941\u091f\u093f:"],"User cancelled login or did not fully authorize.":["\u0909\u092a\u092f\u094b\u0917\u0915\u0930\u094d\u0924\u093e \u0928\u0947 \u0932\u0949\u0917\u093f\u0928 \u0930\u0926\u094d\u0926 \u0915\u0930 \u0926\u093f\u092f\u093e \u092f\u093e \u092a\u0942\u0930\u0940 \u0924\u0930\u0939 \u0938\u0947 \u0905\u0927\u093f\u0915\u0943\u0924 \u0928\u0939\u0940\u0902 \u0915\u093f\u092f\u093e\u0964"],"Failed to login. Please try again.":["\u0932\u0949\u0917\u093f\u0928 \u0915\u0930\u0928\u0947 \u092e\u0947\u0902 \u0935\u093f\u092b\u0932\u0964 \u0915\u0943\u092a\u092f\u093e \u092b\u093f\u0930 \u0938\u0947 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0947\u0902\u0964"],"Authorization failed. Please try again.":["\u0905\u0927\u093f\u0915\u0930\u0923 \u0935\u093f\u092b\u0932\u0964 \u0915\u0943\u092a\u092f\u093e \u092b\u093f\u0930 \u0938\u0947 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0947\u0902\u0964"],"Unexpected error occurred.":["\u0905\u092a\u094d\u0930\u0924\u094d\u092f\u093e\u0936\u093f\u0924 \u0924\u094d\u0930\u0941\u091f\u093f \u0939\u0941\u0908\u0964"],"An error occurred during login. Please try again.":["\u0932\u0949\u0917\u093f\u0928 \u0915\u0947 \u0926\u094c\u0930\u093e\u0928 \u090f\u0915 \u0924\u094d\u0930\u0941\u091f\u093f \u0939\u0941\u0908\u0964 \u0915\u0943\u092a\u092f\u093e \u092b\u093f\u0930 \u0938\u0947 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0947\u0902\u0964"],"Please enter your email.":["\u0915\u0943\u092a\u092f\u093e \u0905\u092a\u0928\u093e \u0908\u092e\u0947\u0932 \u0926\u0930\u094d\u091c \u0915\u0930\u0947\u0902\u0964"],"Something went wrong.":["\u0915\u0941\u091b \u0917\u0932\u0924 \u0939\u094b \u0917\u092f\u093e\u0964"],"Both fields are required.":["\u0926\u094b\u0928\u094b\u0902 \u092b\u093c\u0940\u0932\u094d\u0921 \u0906\u0935\u0936\u094d\u092f\u0915 \u0939\u0948\u0902\u0964"],"Resetting password\u2026":["\u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u0930\u0940\u0938\u0947\u091f \u0939\u094b \u0930\u0939\u093e \u0939\u0948\u2026"],"Invalid reset link.":["\u0905\u092e\u093e\u0928\u094d\u092f \u0930\u0940\u0938\u0947\u091f \u0932\u093f\u0902\u0915\u0964"],"Password reset successful. Redirecting to login\u2026":["\u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u0930\u0940\u0938\u0947\u091f \u0938\u092b\u0932\u0964 \u0932\u0949\u0917\u093f\u0928 \u0915\u0947 \u0932\u093f\u090f \u092a\u0941\u0928\u0930\u094d\u0928\u093f\u0930\u094d\u0926\u0947\u0936\u093f\u0924 \u0915\u093f\u092f\u093e \u091c\u093e \u0930\u0939\u093e \u0939\u0948\u2026"],"Reset failed.":["\u0930\u0940\u0938\u0947\u091f \u0935\u093f\u092b\u0932\u0964"],"We couldn't send the reset email. Please try again or contact support.":["\u0939\u092e \u0930\u0940\u0938\u0947\u091f \u0908\u092e\u0947\u0932 \u0928\u0939\u0940\u0902 \u092d\u0947\u091c \u0938\u0915\u0947\u0964 \u0915\u0943\u092a\u092f\u093e \u092b\u093f\u0930 \u0938\u0947 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0947\u0902 \u092f\u093e \u0938\u0939\u093e\u092f\u0924\u093e \u0938\u0947 \u0938\u0902\u092a\u0930\u094d\u0915 \u0915\u0930\u0947\u0902\u0964"]}}}