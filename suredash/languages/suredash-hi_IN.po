#: inc/modules/email-notifications/email-notifications.php:107
msgid "<p>Hi {{user_first_name}},</p><p>We have an important update regarding the upcoming event <strong>{{event_title}}</strong> on <strong>{{portal_name}}</strong>.</p><p>We want to make sure you have the latest information to ensure you don't miss out on this valuable opportunity. Please take a moment to review the updated details.</p><p><strong>Event: {{event_title}}</strong></p><p>👉 <strong>View the complete updated details:</strong> <a href=\"{{event_url}}\">{{event_url}}</a></p><p><strong>Important reminders:</strong></p><ul><li>Check the updated date and time</li><li>Review any changes to the agenda or format</li><li>Note any new requirements or materials needed</li><li>Verify your registration status</li></ul><p>If you have any questions about these updates or need assistance, please don't hesitate to reach out. We're here to help ensure you have the best possible experience.</p><p>Thank you for your understanding, and we look forward to seeing you at the event!</p><p>Stay informed,<br>The {{portal_name}} Team</p>"
msgstr "<p>नमस्ते {{user_first_name}},</p><p>हमारे पास आगामी इवेंट <strong>{{event_title}}</strong> के बारे में एक महत्वपूर्ण अपडेट है जो <strong>{{portal_name}}</strong> पर हो रहा है।</p><p>हम यह सुनिश्चित करना चाहते हैं कि आपके पास नवीनतम जानकारी हो ताकि आप इस मूल्यवान अवसर को न चूकें। कृपया अपडेट किए गए विवरणों की समीक्षा करने के लिए एक क्षण निकालें।</p><p><strong>इवेंट: {{event_title}}</strong></p><p>👉 <strong>पूर्ण अपडेट किए गए विवरण देखें:</strong> <a href=\"{{event_url}}\">{{event_url}}</a></p><p><strong>महत्वपूर्ण अनुस्मारक:</strong></p><ul><li>अपडेट की गई तारीख और समय की जांच करें</li><li>एजेंडा या प्रारूप में किसी भी परिवर्तन की समीक्षा करें</li><li>कोई नई आवश्यकताएँ या सामग्री की आवश्यकता को नोट करें</li><li>अपनी पंजीकरण स्थिति की पुष्टि करें</li></ul><p>यदि आपके पास इन अपडेट के बारे में कोई प्रश्न हैं या सहायता की आवश्यकता है, तो कृपया संपर्क करने में संकोच न करें। हम यह सुनिश्चित करने के लिए यहाँ हैं कि आपके पास सबसे अच्छा अनुभव हो।</p><p>आपकी समझ के लिए धन्यवाद, और हम इवेंट में आपसे मिलने की उम्मीद करते हैं!</p><p>सूचित रहें,<br>टीम {{portal_name}}</p>"

